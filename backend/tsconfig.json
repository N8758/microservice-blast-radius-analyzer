{
  "compilerOptions": {
    "target": "ES2022",

    "module": "Node16",
    "moduleResolution": "Node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}